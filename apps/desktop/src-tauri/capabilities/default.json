{
  "identifier": "default",
  "description": "Default capability set for Zero-Employee Orchestrator desktop app",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:default",
    "core:window:allow-close",
    "core:window:allow-minimize",
    "core:window:allow-maximize",
    "core:window:allow-set-title",
    "core:window:allow-set-size",
    "core:webview:default",
    "shell:default",
    "updater:default"
  ]
}
