{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Zero-Employee Orchestrator",
  "version": "0.1.1",
  "identifier": "com.zero-employee-orchestrator.desktop",
  "build": {
    "frontendDist": "../ui/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "cd ui && pnpm dev",
    "beforeBuildCommand": "cd ui && pnpm build"
  },
  "app": {
    "windows": [
      {
        "title": "Zero-Employee Orchestrator",
        "width": 1280,
        "height": 800,
        "minWidth": 960,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; connect-src 'self' http://localhost:18234 ws://localhost:18234; img-src 'self' data: blob:"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "shortDescription": "AI Business Orchestration Platform",
    "longDescription": "Define business workflows in natural language, orchestrate multiple AI agents with role-based delegation, and execute tasks with human approval and full auditability",
    "createUpdaterArtifacts": false,
    "macOS": {
      "minimumSystemVersion": "10.13"
    },
    "windows": {
      "wix": {
        "language": "en-US"
      }
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/OrosiTororo/Zero-Employee-Orchestrator/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDNCQUY4RjRFQzU5Rjg1QjgKUldTNGhaL0ZUbyt2TzJLOVpmWVlNUHFmS3BTanZMWkNsVlFRUnhLM3czRnBlMzVzMFNIRmFVOEMK"
    }
  }
}
