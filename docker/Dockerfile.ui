FROM node:20-slim

# Security: create non-root user
RUN groupadd -r zeapp -g 1000 && \
    useradd -r -u 1000 -g zeapp -m -d /home/zeapp -s /bin/bash zeapp

WORKDIR /app

# Install pnpm
RUN corepack enable && corepack prepare pnpm@9 --activate

# Copy package files
COPY apps/desktop/ui/package.json apps/desktop/ui/pnpm-lock.yaml* ./

# Install dependencies
RUN pnpm install --frozen-lockfile || pnpm install

# Copy application code
COPY apps/desktop/ui/ .

# Build for production
RUN pnpm build

RUN chown -R zeapp:zeapp /app

USER zeapp

# Serve with lightweight server
RUN npm install -g serve
EXPOSE 5173

CMD ["serve", "-s", "dist", "-l", "5173"]
