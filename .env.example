# Zero-Employee Orchestrator 環境変数

# データベース
DATABASE_URL=sqlite+aiosqlite:///./zpcos.db
# PostgreSQL 使用時: DATABASE_URL=postgresql+asyncpg://user:pass@localhost/zpcos

# セキュリティ
SECRET_KEY=change-this-to-a-random-secret-key

# CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:1420

# デバッグモード
DEBUG=true

# LLM Provider
OPENROUTER_API_KEY=
OPENAI_API_KEY=

# Google OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
