# Zero-Employee Orchestrator 環境変数
# ======================================
# APIキーは必須ではありません。アカウント登録後、設定画面から追加できます。
#
# ⚠️  サブスクリプション（ChatGPT Plus / Gemini Advanced / Claude Pro）と
#     API アクセスは別物です。
#     - サブスクリプション → Web/アプリ向けサービス（プログラムから直接呼べない）
#     - API キー           → 開発者向けの従量課金サービス（別途取得が必要）
#
# 💡 無料で始める方法:
#     1. Google AI Studio (https://aistudio.google.com/) で Gemini API キーを取得
#        → 無料枠あり・クレジットカード不要
#     2. Ollama (https://ollama.com/) でローカル LLM を実行
#        → API キー不要・完全オフライン・無制限

# データベース
DATABASE_URL=sqlite+aiosqlite:///./zero_employee_orchestrator.db
# PostgreSQL 使用時: DATABASE_URL=postgresql+asyncpg://user:pass@localhost/zero_employee_orchestrator

# セキュリティ
SECRET_KEY=change-this-to-a-random-secret-key

# CORS
CORS_ORIGINS=["http://localhost:5173","http://localhost:1420"]

# デバッグモード
DEBUG=true

# --- 以下は任意設定（後から設定画面でも追加可能） ---

# LLM Provider（いずれか1つでOK）
# OpenRouter（複数モデルを一括利用・推奨）
OPENROUTER_API_KEY=

# OpenAI（GPT-4o等を直接利用）
OPENAI_API_KEY=

# Anthropic（Claude等を直接利用）
ANTHROPIC_API_KEY=

# Google Gemini（無料枠あり・クレカ不要 → https://aistudio.google.com/ で取得）
GEMINI_API_KEY=

# ローカルモデル（Ollama等・完全無料・APIキー不要）
# Ollama を起動していれば自動検出されます
# OLLAMA_BASE_URL=http://localhost:11434

# Google OAuth (任意)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# 実行モード: quality | speed | cost | free
DEFAULT_EXECUTION_MODE=quality
