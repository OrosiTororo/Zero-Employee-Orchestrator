# Zero-Employee Orchestrator 環境変数
# ======================================
#
# 💡 API キー不要で始める方法（3通り）:
#
#   1. 【サブスクリプションモード】 — 何も設定不要！
#      GPT/Gemini/Copilot/Claude の無料 Web サービスをそのまま利用。
#      設定: DEFAULT_EXECUTION_MODE=subscription
#
#   2. 【Google Gemini 無料 API キー】
#      Google AI Studio で無料取得 (https://aistudio.google.com/)
#      設定: GEMINI_API_KEY=<取得したキー>
#
#   3. 【Ollama ローカル LLM】 完全オフライン・無制限
#      設定: OLLAMA_BASE_URL=http://localhost:11434
#            DEFAULT_EXECUTION_MODE=free
#
# ⚠️  注意: ChatGPT Plus/Gemini Advanced 等のサブスクリプションと
#     別途 API キーは別物です。サブスクリプションモードを使うか、
#     別途 API キーを取得してください。

# データベース
DATABASE_URL=sqlite+aiosqlite:///./zero_employee_orchestrator.db
# PostgreSQL 使用時: DATABASE_URL=postgresql+asyncpg://user:pass@localhost/zero_employee_orchestrator

# セキュリティ
SECRET_KEY=change-this-to-a-random-secret-key

# CORS
CORS_ORIGINS=["http://localhost:5173","http://localhost:1420"]

# デバッグモード
DEBUG=true

# ──────────────────────────────────────────────────────────────────────────
# 実行モード (デフォルト: quality)
# quality      → 最高品質モデル（API キー必要）
# speed        → 高速軽量モデル（API キー必要）
# cost         → コスト効率優先（API キー必要）
# free         → Gemini 無料枠 / Ollama（API キーまたは Ollama 必要）
# subscription → API キー不要！g4f 経由で無料 Web サービスを利用
# ──────────────────────────────────────────────────────────────────────────
DEFAULT_EXECUTION_MODE=quality

# g4f (サブスクリプション/API キー不要モード)
# true の場合、API キー無しで GPT/Gemini/Copilot 等を利用可能
USE_G4F=true

# ──────────────────────────────────────────────────────────────────────────
# 以下は任意設定（設定画面・CLI・API からも追加可能）
#
#   設定画面: アプリの「設定」→「LLM API キー設定」から入力
#   CLI:     zero-employee config set OPENAI_API_KEY
#   API:     PUT /api/v1/config { "key": "OPENAI_API_KEY", "value": "..." }
#
#   .env を編集しなくても、上記の方法で設定できます。
#   設定は ~/.zero-employee/config.json に保存されます。
# ──────────────────────────────────────────────────────────────────────────

# OpenRouter（複数モデルを一括利用・推奨）
OPENROUTER_API_KEY=

# OpenAI（GPT-5.4等を直接利用）
OPENAI_API_KEY=

# Anthropic（Claude等を直接利用）
ANTHROPIC_API_KEY=

# Google Gemini（無料枠あり・クレカ不要 → https://aistudio.google.com/ で取得）
GEMINI_API_KEY=

# ローカルモデル（Ollama等・完全無料・APIキー不要）
# Ollama を起動していれば自動検出されます
# OLLAMA_BASE_URL=http://localhost:11434

# ──────────────────────────────────────────────────────────────────────────
# モデルカタログ設定
# ──────────────────────────────────────────────────────────────────────────
# LLM モデルの定義ファイルパス（デフォルト: apps/api/model_catalog.json）
# モデルの追加・削除・廃止・コスト更新はこのファイルを編集してください。
# アプリ再起動または POST /api/v1/models/reload で反映されます。
# MODEL_CATALOG_PATH=

# Google OAuth (任意)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
