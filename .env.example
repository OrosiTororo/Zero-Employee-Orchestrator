# Zero-Employee Orchestrator Environment Variables
# ======================================
#
# 3 ways to get started WITHOUT an API key:
#
#   1. [Subscription mode] — No setup required!
#      Uses free web services for GPT/Gemini/Copilot/Claude.
#      Set: DEFAULT_EXECUTION_MODE=subscription
#
#   2. [Google Gemini free API key]
#      Get a free key at Google AI Studio (https://aistudio.google.com/)
#      Set: GEMINI_API_KEY=<your-key>
#
#   3. [Ollama local LLM] — Fully offline, unlimited
#      Set: OLLAMA_BASE_URL=http://localhost:11434
#            DEFAULT_EXECUTION_MODE=free
#
# Note: ChatGPT Plus/Gemini Advanced subscriptions are separate from API keys.
# Use subscription mode or obtain a separate API key.

# Database
DATABASE_URL=sqlite+aiosqlite:///./zero_employee_orchestrator.db
# For PostgreSQL: DATABASE_URL=postgresql+asyncpg://user:pass@localhost/zero_employee_orchestrator

# Security
SECRET_KEY=change-this-to-a-random-secret-key

# CORS
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000","tauri://localhost","https://tauri.localhost","http://tauri.localhost"]

# Debug mode
DEBUG=true

# --------------------------------------------------------------------------
# Execution mode (default: quality)
# quality      -> Highest quality models (API key required)
# speed        -> Fast, lightweight models (API key required)
# cost         -> Cost-efficient priority (API key required)
# free         -> Gemini free tier / Ollama (API key or Ollama required)
# subscription -> No API key needed! Uses free web services via g4f
# --------------------------------------------------------------------------
DEFAULT_EXECUTION_MODE=quality

# g4f (subscription / no-API-key mode)
# When true, GPT/Gemini/Copilot etc. available without API keys
USE_G4F=true

# --------------------------------------------------------------------------
# Optional settings below (also configurable via settings UI, CLI, or API)
#
#   Settings UI: App "Settings" -> "LLM API Key Settings"
#   CLI:         zero-employee config set OPENAI_API_KEY
#   API:         PUT /api/v1/config { "key": "OPENAI_API_KEY", "value": "..." }
#
#   You can configure these without editing .env.
#   Settings are saved to ~/.zero-employee/config.json.
# --------------------------------------------------------------------------

# OpenRouter (access multiple models with one account)
OPENROUTER_API_KEY=

# OpenAI (direct access to GPT models)
OPENAI_API_KEY=

# Anthropic (direct access to Claude models)
ANTHROPIC_API_KEY=

# Google Gemini (free tier available, no credit card -> https://aistudio.google.com/)
GEMINI_API_KEY=

# Local models (Ollama etc. — fully free, no API key needed)
# Automatically detected when Ollama is running
# OLLAMA_BASE_URL=http://localhost:11434

# --------------------------------------------------------------------------
# Model catalog settings
# --------------------------------------------------------------------------
# Path to the LLM model definition file (default: apps/api/model_catalog.json)
# Edit this file to add/remove/deprecate models or update costs.
# Reload via app restart or POST /api/v1/models/reload.
# MODEL_CATALOG_PATH=

# --------------------------------------------------------------------------
# Sentry (error monitoring — optional)
# For developers. Get your DSN from your Sentry project settings.
# Also configurable via CLI: zero-employee config set SENTRY_DSN
# Falls back to built-in event store when not configured.
# --------------------------------------------------------------------------
SENTRY_DSN=

# Google OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --------------------------------------------------------------------------
# Production deployment settings (configure before deploying publicly)
# --------------------------------------------------------------------------
# SECRET_KEY will reject the default value when DEBUG=false
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
#
# Production database (PostgreSQL)
# DATABASE_URL=postgresql+asyncpg://user:pass@host/dbname
#
# Production CORS (change to your actual domain)
# CORS_ORIGINS=["https://yourdomain.com"]
#
# Disable debug in production
# DEBUG=false
