# Zero-Employee Orchestrator 環境変数
# ======================================
# APIキーは必須ではありません。アカウント登録後、設定画面から追加できます。

# データベース
DATABASE_URL=sqlite+aiosqlite:///./zero_employee_orchestrator.db
# PostgreSQL 使用時: DATABASE_URL=postgresql+asyncpg://user:pass@localhost/zero_employee_orchestrator

# セキュリティ
SECRET_KEY=change-this-to-a-random-secret-key

# CORS
CORS_ORIGINS=["http://localhost:5173","http://localhost:1420"]

# デバッグモード
DEBUG=true

# --- 以下は任意設定（後から設定画面でも追加可能） ---

# LLM Provider（いずれか1つでOK）
# OpenRouter（複数モデルを一括利用・推奨）
OPENROUTER_API_KEY=

# OpenAI（GPT-4o等を直接利用）
OPENAI_API_KEY=

# Anthropic（Claude等を直接利用）
ANTHROPIC_API_KEY=

# ローカルモデル（Ollama等・完全無料）
# Ollama を起動していれば自動検出されます
# OLLAMA_BASE_URL=http://localhost:11434

# Google OAuth (任意)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# 実行モード: quality | speed | cost | free
DEFAULT_EXECUTION_MODE=quality
